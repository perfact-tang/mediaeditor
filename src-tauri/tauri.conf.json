{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaSplitter AI",
  "version": "0.1.0",
  "identifier": "com.mediasplitter.ai",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MediaSplitter AI",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost http://127.0.0.1:*; connect-src ipc: http://ipc.localhost http://127.0.0.1:*",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DOWNLOAD/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$VIDEO/**",
          "$AUDIO/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/bin/*",
      "resources/models/ggml-base.bin"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "category": "Video",
    "shortDescription": "Fast video and audio splitter",
    "longDescription": "MediaSplitter AI imports media, lets users define manual segments, and exports video or audio with FFmpeg."
  }
}
